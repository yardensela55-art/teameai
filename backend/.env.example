# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically if you add a
# Postgres plugin to the backend service)
DATABASE_URL=postgresql://user:password@host:5432/database

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=

# ── AI ─────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── App URLs ───────────────────────────────────────────────────────────────────
# Public URL of the frontend service (used for CORS)
# Example: https://teame-frontend.up.railway.app
FRONTEND_URL=

# Port the backend listens on (Railway sets this automatically)
PORT=3001

# ── Email — Resend ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
INVITE_FROM_EMAIL=noreply@yourdomain.com

# ── Jira OAuth ─────────────────────────────────────────────────────────────────
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# Must match exactly what you registered in the Jira developer console
# Example: https://teame-backend.up.railway.app/api/integrations/jira/callback
JIRA_REDIRECT_URI=

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Calendar integration callback
# Example: https://teame-backend.up.railway.app/api/integrations/google/callback
GOOGLE_REDIRECT_URI=
# Google Sign-In callback
# Example: https://teame-backend.up.railway.app/api/auth/google/callback
GOOGLE_LOGIN_REDIRECT_URI=
